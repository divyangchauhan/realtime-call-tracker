# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=calluser
POSTGRES_PASSWORD=callpass
POSTGRES_DB=calltracker

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AWS / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT=http://localstack:4566
S3_BUCKET=call-recordings

# Recording worker
# Path to the mock MP3 file uploaded to S3 for every completed call.
# Resolved against process.cwd(); default works from the project root or /app in Docker.
MOCK_RECORDING_PATH=assets/mock_recording.mp3

# Database migrations
DB_RUN_MIGRATIONS=true

# Seed
SEED_API_KEY=dev-secret-key

# Call state
CALL_STATE_TTL_SECONDS=3600
WS_PUBLIC_URL=ws://localhost:3000/ws

# Call progression engine
# All durations are in milliseconds. Probability is a float 0-1.
# Defaults produce a realistic fast-moving demo: QUEUED -> RINGING in 1s,
# rings for 2s, then ANSWERED -> COMPLETED in 3s (or UNANSWERED -> COMPLETED in 0.5s).
PROGRESSION_QUEUED_TO_RINGING_MS=1000
PROGRESSION_RINGING_MS=2000
PROGRESSION_ANSWERED_TO_COMPLETED_MS=3000
PROGRESSION_UNANSWERED_TO_COMPLETED_MS=500
PROGRESSION_ANSWER_PROBABILITY=0.7

# Write-behind flush reconciliation
# Period (ms) between CallFlushService passes that reconcile Redis write-behind
# intermediate statuses (RINGING/ANSWERED/UNANSWERED) into Postgres.
FLUSH_INTERVAL_MS=5000
